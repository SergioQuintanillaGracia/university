Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AC", "[", 
     RowBox[{
     "inicial_List", ",", " ", "regla_Integer", ",", " ", "t_Integer"}], 
     "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "bindigits", ",", "prevstate", ",", "newstate", ",", "i", ",", "j", ",",
         "left", ",", "center", ",", "right", ",", "len", ",", "currnum", ",",
         "num", ",", "alldata", ",", "frames"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Obtenemos", " ", "la", " ", "representaci\[OAcute]n", " ", "binaria", 
        " ", "al", " ", "rev\[EAcute]s", " ", "de", " ", "la", " ", "regla"}],
        " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"bindigits", "=", 
        RowBox[{"IntegerDigits", "[", 
         RowBox[{"regla", ",", "2", ",", "8"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"bindigits", "=", 
        RowBox[{"Reverse", "[", "bindigits", "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"len", "=", 
        RowBox[{"Length", "[", "inicial", "]"}]}], ";", "\[IndentingNewLine]",
        "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Inicializamos", " ", "alldata", " ", "con", " ", "varias", " ", 
         "rows", " ", "de", " ", "0", "s", " ", "que", " ", "utilizaremos", " ",
          "m\[AAcute]s", " ", "adelante", " ", "para", " ", "generar", " ", 
         "los", " ", "frames"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"alldata", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"len", "-", "1"}], ",", "len"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"alldata", ",", "inicial"}], "]"}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Escribimos", " ", "el", " ", "n\[UAcute]mero", " ", "al", " ", "que",
          " ", "transicionamos", " ", "en", " ", "cada", " ", 
         "posici\[OAcute]n", " ", "de", " ", "inicial", " ", "en", " ", 
         "newstate", " ", "para", " ", "calcular", " ", "el", " ", 
         "siguiente", " ", "estado"}], " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{"prevstate", "=", "inicial"}], ";", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"j", "=", "0"}], ",", 
         RowBox[{"j", "<", "t"}], ",", 
         RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"newstate", "=", 
           RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"i", "=", "0"}], ",", 
            RowBox[{"i", "<", "len"}], ",", 
            RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
            RowBox[{"(*", " ", 
             RowBox[{
              RowBox[{
              "Calculamos", " ", "un", " ", "n\[UAcute]mero", " ", "en", " ", 
               "base", " ", "10", " ", "correspondiente", " ", "al", " ", 
               "d\[IAcute]gito", " ", "izquierdo"}], ",", " ", 
              RowBox[{
              "central", " ", "y", " ", "derecho", " ", "de", " ", "la", " ", 
               "posici\[OAcute]n", " ", "que", " ", "estamos", " ", 
               "considerando"}]}], " ", "*)"}], "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"left", "=", 
              RowBox[{
               RowBox[{"Mod", "[", 
                RowBox[{
                 RowBox[{"i", "+", "len", "-", "1"}], ",", "len"}], "]"}], 
               " ", "+", " ", "1"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"center", "=", 
              RowBox[{"i", " ", "+", " ", "1"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"right", "=", 
              RowBox[{
               RowBox[{"Mod", "[", 
                RowBox[{
                 RowBox[{"i", "+", "1"}], ",", "len"}], "]"}], " ", "+", " ", 
               "1"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"currnum", "=", 
              RowBox[{"FromDigits", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"prevstate", "[", 
                   RowBox[{"[", "left", "]"}], "]"}], ",", 
                  RowBox[{"prevstate", "[", 
                   RowBox[{"[", "center", "]"}], "]"}], ",", 
                  RowBox[{"prevstate", "[", 
                   RowBox[{"[", "right", "]"}], "]"}]}], "}"}], ",", "2"}], 
               "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
             RowBox[{"(*", " ", 
              RowBox[{
               RowBox[{
               "El", " ", "n\[UAcute]mero", " ", "por", " ", "el", " ", "que",
                 " ", "sustituiremos", " ", "al", " ", "actual", " ", 
                "est\[AAcute]", " ", "en", " ", "la", " ", "posici\[OAcute]n",
                 " ", "currnum"}], " ", "+", " ", 
               RowBox[{"1", " ", "en", " ", "bindigits"}]}], " ", "*)"}], 
             "\[IndentingNewLine]", 
             RowBox[{"num", "=", 
              RowBox[{"bindigits", "[", 
               RowBox[{"[", 
                RowBox[{"currnum", "+", "1"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"newstate", ",", "num"}], "]"}], ";"}]}], 
           "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"alldata", ",", "newstate"}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"prevstate", "=", "newstate"}], ";"}]}], 
        "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Calculamos", " ", "los", " ", "frames", " ", "con", " ", "una", " ", 
         "sliding", " ", "window", " ", "sobre", " ", "alldata"}], " ", 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"frames", "=", 
        RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"i", "<=", 
          RowBox[{
           RowBox[{"Length", "[", "alldata", "]"}], "-", "len"}]}], ",", 
         RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"frames", ",", 
           RowBox[{"ArrayPlot", "[", 
            RowBox[{"alldata", "[", 
             RowBox[{"[", 
              RowBox[{"i", ";;", 
               RowBox[{"i", "+", "len", "-", "1"}]}], "]"}], "]"}], "]"}]}], 
          "]"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"ListAnimate", "[", "frames", "]"}]}]}], "\[IndentingNewLine]",
      "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"AC", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "1", ",", "0", ",", "1", ",", "0", ",", "1", ",", "1", ",", "1", ",", "0",
