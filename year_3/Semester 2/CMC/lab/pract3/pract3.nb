d3b64c8a0d99"],

Cell["\<\
Implemente un m\[OAcute]dulo Mathematica que, tomando como entrada una cadena \
arbitraria y un AC unidimensional por la izquierda que reconoce un lenguaje \
mediante entrada paralela en tiempo real proporcione como salida True si el \
AC acepta la cadena y False en caso contrario. Considere que el estado de \
fronteria quiescente es siempre el estado q E S.\
\>", "Text",
 CellChangeTimes->{{3.985152776114064*^9, 3.9851527763961353`*^9}, {
  3.9851529449968157`*^9, 3.98515299803168*^9}, {3.986353931403729*^9, 
  3.9863539315059137`*^9}},ExpressionUUID->"4412ca1b-247f-4c51-85e7-\
c61b0e18268c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ACacepta", "[", 
    RowBox[{"automata_List", ",", " ", "cadenaIn_List"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "cadenaOut", ",", "cadenaTemp", ",", "states", ",", "transitions", ",", 
       "statesAcep", ",", "n", ",", "x", ",", "y", ",", "prev", ",", "curr", ",",
        "new", ",", "matchingTransitions", ",", "transition"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"states", "=", 
       RowBox[{"automata", "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"transitions", "=", 
       RowBox[{"automata", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"statesAcep", "=", 
       RowBox[{"automata", "[", 
        RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "cadenaIn", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"cadenaOut", "=", "cadenaIn"}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Repetiremos", " ", "tantas", " ", "veces", " ", "como", " ", 
        "caracteres", " ", "haya", " ", "en", " ", "la", " ", "cadena"}], " ",
        "*)"}], "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"x", "=", "1"}], ",", 
        RowBox[{"x", "<=", "n"}], ",", 
        RowBox[{"x", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Reemplazamos", " ", "cada", " ", "caracter", " ", "de", " ", "la", " ",
           "cadena", " ", "por", " ", "el", " ", "caracter", " ", 
          "correspondiente", "\[IndentingNewLine]", "seg\[UAcute]n", " ", 
          "las", " ", "reglas", " ", "de", " ", "transici\[OAcute]n"}], " ", 
         "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"cadenaTemp", "=", "cadenaOut"}], ";", "\[IndentingNewLine]", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"y", "=", "1"}], ",", 
           RowBox[{"y", "<=", "n"}], ",", 
           RowBox[{"y", "++"}], ",", "  ", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"y", "==", "1"}], ",", "\[IndentingNewLine]", 
              RowBox[{"prev", "=", "q"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"prev", "=", 
                RowBox[{"cadenaTemp", "[", 
                 RowBox[{"[", 
                  RowBox[{"y", "-", "1"}], "]"}], "]"}]}], ";"}]}], 
             "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{"curr", "=", 
             RowBox[{"cadenaTemp", "[", 
              RowBox[{"[", "y", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            "\[IndentingNewLine]", 
            RowBox[{"(*", " ", 
             RowBox[{
              RowBox[{
              "Si", " ", "no", " ", "hay", " ", "transiciones", " ", 
               "v\[AAcute]lidas"}], ",", " ", 
              RowBox[{"devolvemos", " ", "False"}]}], " ", "*)"}], 
            "\[IndentingNewLine]", 
            RowBox[{"matchingTransitions", "=", 
             RowBox[{"Cases", "[", 
              RowBox[{"transitions", ",", 
               RowBox[{"{", 
                RowBox[{"prev", ",", "curr", ",", "_"}], "}"}]}], "]"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Length", "[", "matchingTransitions", "]"}], "==", 
               "0"}], ",", "\[IndentingNewLine]", 
              RowBox[{
               RowBox[{"Return", "[", "False", "]"}], ";"}]}], 
             "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
            "\[IndentingNewLine]", 
            RowBox[{"transition", "=", 
             RowBox[{"matchingTransitions", "[", 
              RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"new", "=", 
             RowBox[{"transition", "[", 
              RowBox[{"[", "3", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"cadenaOut", "[", 
              RowBox[{"[", "y", "]"}], "]"}], "=", "new"}], ";"}]}], 
          "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", "]"}],
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "La", " ", "cadena", " ", "est\[AAcute]", " ", "en", " ", "el", " ", 
        "lenguaje", " ", "si", " ", "el", " ", "estado", " ", "m\[AAcute]s", " ",
         "a", " ", "la", " ", "derecha", " ", "est\[AAcute]", " ", "en", " ", 
        "la", " ", "lista", " ", "de", "\[IndentingNewLine]", "estados", " ", 
        "de", " ", "aceptaci\[OAcute]n"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"MemberQ", "[", 
        RowBox[{"statesAcep", ",", 
         RowBox[{"cadenaOut", "[", 
          RowBox[{"[", "n", "]"}], "]"}]}], "]"}], "]"}], ";"}]}], 
    "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
