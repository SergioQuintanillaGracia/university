Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"mei", "[", 
    RowBox[{"i_Integer", ",", "j_Integer", ",", "l1_", ",", "l2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"memoria", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "\[LessEqual]", " ", 
        RowBox[{"memoria", "[", 
         RowBox[{"[", "j", "]"}], "]"}]}], ",", 
       RowBox[{"Goto", "[", "l1", "]"}], ",", 
       RowBox[{"Goto", "[", "l2", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
