Cell[TextData[StyleBox["Ejemplo: Calcular el factorial de un valor entero \
positivo almacenado en el registro j de una m\[AAcute]quina RAM. \nConsidere \
j distinto de los registros  1, 3 \[OAcute] 4.",
 FontSize->18,
 Background->GrayLevel[0.85]]], "Text",
 CellChangeTimes->{{3.939362738080018*^9, 3.939362843815092*^9}, {
   3.939362883803724*^9, 3.939362884389452*^9}, 3.93936292078783*^9, {
   3.939362975139091*^9, 3.939362977329084*^9}, 
   3.98152659025218*^9},ExpressionUUID->"8ce72b0c-1aab-483e-9ae0-\
82bab46d8148"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"factorial", "[", "j_Integer", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\t\t  ", 
     RowBox[{
      RowBox[{"cop", "[", 
       RowBox[{"j", ",", "3"}], "]"}], ";", "\n", "\t\t\t", 
      RowBox[{"cer", "[", "4", "]"}], ";", "\n", "\t\t\t", 
      RowBox[{"ig", "[", 
       RowBox[{"3", ",", "4", ",", "cero", ",", "nocero"}], "]"}], ";", "\n", 
      StyleBox[
       RowBox[{"Label", "[", "cero", "]"}],
       FontColor->GrayLevel[0]], ";", 
      RowBox[{"suc", "[", "4", "]"}], ";", "\n", "\t\t\t", 
      RowBox[{"Goto", "[", "fin", "]"}], ";", "\n", 
      RowBox[{"Label", "[", "nocero", "]"}], ";", " ", 
      RowBox[{"asi", "[", 
       RowBox[{"1", ",", "4"}], "]"}], ";", "\n", 
      RowBox[{"Label", "[", "bucle", "]"}], ";", " ", 
      RowBox[{"mul", "[", 
       RowBox[{"3", ",", "4", ",", "4"}], "]"}], ";", "\n", "\t\t\t", 
      RowBox[{"pre", "[", 
       RowBox[{"3", ",", "fin"}], "]"}], ";", " ", "\n", "\t\t\t", 
      RowBox[{"pre", "[", 
       RowBox[{"3", ",", "fin"}], "]"}], ";", "\n", "\t\t\t", 
      RowBox[{"suc", "[", "3", "]"}], ";", "\n", "\t\t\t", 
      RowBox[{"Goto", "[", "bucle", "]"}], ";", "\n", 
      RowBox[{"Label", "[", "fin", "]"}], ";", " ", 
      RowBox[{"cop", "[", 
       RowBox[{"4", ",", "1"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.919346370301377*^9, 3.919346767393962*^9}, {
   3.919346875194086*^9, 3.919346951851255*^9}, {3.9193471255781527`*^9, 
   3.919347187679174*^9}, {3.91934726857008*^9, 3.919347292948555*^9}, 
   3.919347396482733*^9, {3.919347517848366*^9, 3.919347518366581*^9}, 
