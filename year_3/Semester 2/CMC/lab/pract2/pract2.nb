Cell[BoxData[
 RowBox[{
  RowBox[{"div", "[", 
   RowBox[{"i_Integer", ",", "j_Integer", ",", "k_Integer"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"memoria", "[", 
        RowBox[{"[", "j", "]"}], "]"}], "\[Equal]", "0"}], ",", 
      RowBox[{"Return", "[", "\"\<error\>\"", "]"}], ",", 
      RowBox[{
       RowBox[{"memoria", "[", 
        RowBox[{"[", "k", "]"}], "]"}], "=", 
       RowBox[{"IntegerPart", "[", 
        RowBox[{
         RowBox[{"memoria", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "/", 
         RowBox[{"memoria", "[", 
          RowBox[{"[", "j", "]"}], "]"}]}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
